BOOST_ROOT = $(HOME)/boost-1.81

CXX = g++-12
CXXFLAGS = -I$(BOOST_ROOT)/include \
           -std=c++20 \
           -march=native \
           -O3 -g \
           -Wall -pedantic \
           -Wno-ignored-attributes \
           -fopenmp \
           -msse2 -mssse3 -maes -mpclmul \
           -DBOOST_ERROR_CODE_HEADER_ONLY \
           -DBOOST_ASIO_HAS_CO_AWAIT \
           -pthread

LIBS = -lbsd

# prg-bitsliced (LowMC) lives in a subdirectory; the merged sabre audit pulls
# its headers. -mavx2 for block<__m256i>, -lcrypto because streams.h includes
# openssl/sha.h.
PRG_DIR     = prg-bitsliced
SABRE_EXTRA = -mavx2 -I$(PRG_DIR)
SABRE_LIBS  = -lcrypto


REMISE      = remise
REMISE_SRC  = remise.cpp

REMISE_SABRE     = remise_sabre
REMISE_SABRE_SRC = remise_sabre.cpp

all:  $(REMISE) $(REMISE_SABRE)


$(REMISE): $(REMISE_SRC) dpf.hpp types.hpp network.hpp
	$(CXX) $(CXXFLAGS) $(REMISE_SRC) -o $(REMISE) $(LIBS)

# Requires prg-bitsliced/lowmc/constants_b128_r29_s11.h to exist first
# (generated by building prg-bitsliced). See note below.
$(REMISE_SABRE): $(REMISE_SABRE_SRC) dpf.hpp types.hpp network.hpp
	$(CXX) $(CXXFLAGS) $(SABRE_EXTRA) $(REMISE_SABRE_SRC) -o $(REMISE_SABRE) $(LIBS) $(SABRE_LIBS)

run-remise: $(REMISE)
	./$(REMISE)

run-remise-sabre: $(REMISE_SABRE)
	./$(REMISE_SABRE)

clean:
	rm -f $(REMISE) $(REMISE_SABRE)
